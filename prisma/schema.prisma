// 대동CMC 통합 ERP — Prisma schema
// SQLite for local dev. Production = PostgreSQL (Supabase) — change provider when migrating.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  // 로컬 개발은 sqlite 권장(빠름), 운영은 postgresql.
  // DATABASE_URL 환경변수로 둘 다 지원하려면 provider도 env 가능한 라인을 분기해야 하는데,
  // Prisma는 provider를 env에서 못 받으므로 운영 기준으로 postgresql 고정.
  // 로컬에서 sqlite로 돌리려면 provider를 sqlite로 변경하고 DATABASE_URL="file:./dev.db" 사용.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────── 직원 ─────────────────────────────────
model User {
  id                 String   @id @default(cuid())
  empNo              String   @unique
  name               String
  residentNo         String?  // 주민등록번호 (full or masked)
  email              String?
  phone              String?
  mobile             String?
  dept               String
  position           String
  positionTitle      String?  // 직책
  role               String   // admin / manager / staff
  pmCode             String?  @unique
  joinDate           DateTime?
  joinType           String?  // 입사구분 (정규직/계약직/인턴 등)
  leaveDate          DateTime?
  leaveReason        String?
  status             String   @default("active") // active / inactive / leave
  // 급여통장
  bankName           String?
  accountNo          String?
  accountHolder      String?
  // 주소
  postCode           String?
  address            String?
  // 기타
  passportNo         String?
  foreignName1       String?
  foreignName2       String?
  householderType    String?  // head / member / spouse
  annualLeaveTotal   Float    @default(0)
  annualLeaveUsed    Float    @default(0)
  isInternal         Boolean  @default(false) // 내부직원 여부 (연차/근태 대상)
  // 컨설턴트 MD
  consultantGrade    String?  // 1급 / 2급 / 3급 / 4급 등 — 미설정시 MD 플래너 미참여
  consultantRate     BigInt   @default(0) // 컨설턴트 일단가 (원). consultantGrade 있으면 0 이상
  passwordHash       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  managedProjects    Project[] @relation("ProjectManager")
  expenseRequests    ExpenseRequest[] @relation("ExpenseRequester")
  approvedExpenses   ExpenseRequest[] @relation("ExpenseApprover")
  attendance         Attendance[]
  leaveRequests      LeaveRequest[] @relation("LeaveRequester")
  approvedLeaves     LeaveRequest[] @relation("LeaveApprover")
  leaveApprovals     LeaveApproval[] @relation("LeaveApprovalApprover")
  educations         UserEducation[]
  certificates       Certificate[]    @relation("UserCertificates")
  managedConsultantPlans   ConsultantPlan[]       @relation("ConsultantPlanManager")
  consultantAssignments    ConsultantAssignment[] @relation("ConsultantAssignmentConsultant")
  tripReports              TripReport[]
}

// ─────────────────────────────── 업체/거래처 ───────────────────────────────
model Company {
  id             String    @id @default(cuid())
  name           String
  bizNo          String?   @unique
  repName        String?
  address        String?
  region         String?
  type           String    @default("client") // client / agency / partner / etc
  website        String?
  industry       String?
  corpType       String?
  foundedAt      DateTime?
  rating         String?   // P / A / B 등급
  internalPmCode String?   // 대동CMC 내부 담당 PM (JHC, JYP 등)
  items          String?   // 주요 아이템/제품
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contacts          CompanyContact[]
  clientProjects    Project[] @relation("ProjectClient")
  agencyProjects    Project[] @relation("ProjectAgency")
  taxInvoices       TaxInvoice[]
  mgmtFeeBudgets    MgmtFeeBudget[]  @relation("MgmtFeeClient")
  mgmtFeeExpenses   MgmtFeeExpense[] @relation("MgmtFeeVendor")
  trackRecords      TrackRecord[]    @relation("TrackRecordClient")
}

// 역할별 섹션 권한 매트릭스
model Permission {
  id        String   @id @default(cuid())
  role      String   // admin / manager / staff
  section   String   // dashboard / projects / managers / companies / invoices / card_purchases / expenses / contracts / users / accounts / permissions / settings
  canView   Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([role, section])
  @@index([role])
}

// 재직/경력증명서 발급 이력
model Certificate {
  id          String   @id @default(cuid())
  certNo      String   @unique  // 발급번호 (예: 2026-33)
  type        String   // employment(재직) / career(경력)
  userId      String
  purpose     String?  // 용도
  issueDate   DateTime // 발행일
  startDate   DateTime? // 근무 시작일 (보통 입사일)
  endDate     DateTime? // 근무 종료일 (재직증명서면 발행일, 경력증명서면 퇴사일)
  customBody  String?   // 사용자 직접 수정 본문 (null이면 자동 생성)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserCertificates", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([issueDate])
}

// 직원 학력 (인사카드 인쇄용)
model UserEducation {
  id            String   @id @default(cuid())
  userId        String
  level         String   // 고졸 / 전문대 / 대학 / 대학원-석사 / 대학원-박사 등
  schoolName    String
  major         String?  // 전공
  location      String?  // 소재지
  enterDate     DateTime?
  graduateDate  DateTime?
  daytime       String?  // 주간 / 야간 / 사이버
  graduateType  String?  // 졸업 / 재학 / 휴학 / 중퇴
  note          String?
  sortOrder     Int      @default(0)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CompanyContact {
  id        String  @id @default(cuid())
  companyId String
  name      String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean @default(true)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────── 프로젝트 ───────────────────────────────
model Project {
  id                 String   @id @default(cuid())
  projectCode        String   @unique
  displayCode        String?  // 노션 '구분' 칼럼 (a01, b02 등) — 화면 표시용
  year               Int
  title              String
  content            String?  // 발굴 시트의 '내용' 칼럼
  selfFunding        Float?   // 발굴 시트의 '자부담' (단위 백만원, 노션 표기 그대로)
  sortOrder          Int      @default(0)
  companyId          String?
  agencyId           String?
  bizCategory        String   // innovation / export / contract / certification / rental
  serviceType        String?
  serviceDetail      String?
  status             String   @default("request_received")
  pmCode             String?
  managerId          String?
  confirmedRevenue   BigInt   @default(0)
  expectedRevenue    BigInt   @default(0) // 발굴 시트의 예상매출 (단위 백만원이 아닌 원 기준으로 저장)
  source             String   @default("nurture") // discovery(발굴) / nurture(육성)
  confirmedYn        Boolean  @default(false)     // 발굴 시트의 확정 칼럼
  nurtureType        String?  // new / nurture
  region             String?
  startDate          DateTime?
  endDate            DateTime?
  isAdvance          Boolean  @default(false)
  isBalance          Boolean  @default(false)
  parentProjectCode  String?
  requestStatus      String?  // received / submitted / na
  agreementYn        Boolean  @default(false)
  advancePaidYn      Boolean  @default(false)
  midReportDate      DateTime?
  midReportYn        Boolean  @default(false)
  finalReportDate    DateTime?
  finalReportYn      Boolean  @default(false)
  revisionYn         Boolean  @default(false)
  keyword            String?
  notes              String?
  remarks            String?  // 구글시트의 '특이사항'
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company       Company? @relation("ProjectClient", fields: [companyId], references: [id])
  agency        Company? @relation("ProjectAgency", fields: [agencyId], references: [id])
  manager       User?    @relation("ProjectManager", fields: [managerId], references: [id])
  deliverables  ProjectDeliverable[]
  taxInvoices   TaxInvoice[]
  expenses      ExpenseRequest[]
  mgmtFeeBudgets MgmtFeeBudget[]
  histories     ProjectHistory[]
  consultantPlans ConsultantPlan[]

  @@index([status])
  @@index([bizCategory])
  @@index([pmCode])
  @@index([year])
}

// 드롭다운 옵션 (사용자 정의 추가 옵션)
//   하드코딩 enum(BIZ_CATEGORY 등)은 그대로 두고, 이 테이블의 row는 추가 옵션으로 머지된다.
//   category: bizCategory / projectStatus / serviceType / nurtureType / requestStatus / serviceDetail / region 등
//   sortOrder는 Float로, 하드코딩 옵션 사이에 fractional value (예: 4.5)로 끼워넣을 수 있게.
model DropdownOption {
  id        String   @id @default(cuid())
  category  String
  value     String
  label     String
  color     String?
  sortOrder Float    @default(0)
  createdAt DateTime @default(now())

  @@unique([category, value])
  @@index([category])
}

// 프로젝트 특이사항/히스토리 메모 (제목 옆 서류 아이콘으로 표시)
model ProjectHistory {
  id          String   @id @default(cuid())
  projectId   String
  body        String
  createdById String?
  createdByName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectDeliverable {
  id            String   @id @default(cuid())
  projectId     String
  seq           Int
  title         String
  type          String?  // report / product / design / website / document / other
  isCompleted   Boolean  @default(false)
  dueDate       DateTime?
  completedDate DateTime?
  fileUrl       String?
  notes         String?

  // 검토 워크플로우
  reviewStatus       String    @default("pending")
  // pending(미검토) / in_review(검토중) / approved(완료) / revision(보완필요)
  reviewSubmittedAt  DateTime?
  reviewedAt         DateTime?
  reviewedById       String?
  reviewFeedback     String?

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([reviewStatus])
}

// 카드 매입 (법인카드 매입내역) — 엑셀 업로드용
model CardPurchase {
  id            String    @id @default(cuid())
  approvalNo    String?   @unique  // 승인번호 (있으면)
  approvalDate  DateTime  // 승인일자
  cardNo        String?   // 카드번호 (마스킹된)
  cardName      String?   // 카드명
  merchantName  String    // 가맹점명
  merchantBizNo String?
  category      String?   // 업종
  amount        BigInt    @default(0) // 청구금액(총액)
  supplyAmount  BigInt    @default(0)
  taxAmount     BigInt    @default(0)
  installment   String?   // 할부
  note          String?
  sourceFile    String?
  createdAt     DateTime  @default(now())

  @@index([approvalDate])
  @@index([merchantName])
}

// 전자근로계약서
model LaborContract {
  id              String   @id @default(cuid())
  title           String   // 계약서명
  category        String?  // 구분명 (표준근로계약서, 비밀유지서약서 등)
  dept            String?
  projectId       String?
  fileUrl         String?  // 첨부 PDF 경로
  fileName        String?
  message         String?  // 전달메시지
  use2FA          Boolean  @default(false) // 2차인증사용 여부

  // 수신자 정보 (인사관리에서 매칭)
  recipientUserId String?
  recipientName   String?
  recipientEmail  String?
  recipientPhone  String?
  deliveryMethod  String?  // email / sms / kakao / direct

  // 진행 단계
  stage           String   @default("draft")
  // draft(계약서 작성) → requested(요청완료) → signed(서명완료) → cancelled(취소) → rejected(반려)
  requestedAt     DateTime?
  signedAt        DateTime?
  signatureUrl    String?  // 서명 데이터 (base64 이미지)

  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([stage])
  @@index([recipientUserId])
}

// 홈택스에서 다운로드한 전자세금계산서 목록 (엑셀 업로드용, 프로젝트와 별도)
model ElectronicTaxInvoice {
  id               String   @id @default(cuid())
  type             String   // sales / purchase
  approvalNo       String   @unique  // 승인번호
  writeDate        DateTime  // 작성일자
  issueDate        DateTime? // 발급일자
  sendDate         DateTime? // 전송일자

  // 공급자
  supplierBizNo    String
  supplierSubNo    String?  // 종사업장번호
  supplierName     String
  supplierRep      String?
  supplierAddr     String?
  supplierEmail    String?

  // 공급받는자
  buyerBizNo       String
  buyerSubNo       String?
  buyerName        String
  buyerRep         String?
  buyerAddr        String?
  buyerEmail       String?
  buyerEmail2      String?

  // 금액
  totalAmount      BigInt   @default(0)
  supplyAmount     BigInt   @default(0)
  taxAmount        BigInt   @default(0)

  // 메타
  category         String?  // 전자세금계산서분류 (세금계산서/계산서 등)
  invoiceKind      String?  // 전자세금계산서종류 (일반/영세율 등)
  issueType        String?  // 발급유형
  note             String?
  paymentType      String?  // 영수/청구

  // 대표 품목
  itemDate         DateTime?
  itemName         String?
  itemSpec         String?
  itemQty          String?
  itemUnitPrice    String?
  itemNote         String?

  sourceFile       String?  // 원본 파일명 (감사용)
  createdAt        DateTime @default(now())

  trackRecords     TrackRecord[] @relation("TrackRecordTaxInvoice")

  @@index([type])
  @@index([writeDate])
  @@index([type, writeDate])
  @@index([supplierBizNo])
  @@index([buyerBizNo])
}

model TaxInvoice {
  id              String   @id @default(cuid())
  projectId       String
  companyId       String?
  invoiceNo       String?
  amount          BigInt
  issueDate       DateTime?
  issuedYn        Boolean  @default(false)
  vatReceivedYn   Boolean  @default(false)
  settlementDoneYn Boolean @default(false)
  paymentDoneYn   Boolean  @default(false)
  paymentDate     DateTime?
  description     String?
  createdAt       DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@index([issueDate])
  @@index([issuedYn, issueDate])
}

// ─────────────────────────────── 지출결의 ───────────────────────────────
model ExpenseRequest {
  id              String   @id @default(cuid())
  expenseNo       String   @unique
  title           String
  projectId       String?
  companyId       String?
  taxInvoiceId    String?  // 매칭된 전자세금계산서
  category        String
  amount          BigInt
  description     String?
  requesterId     String
  requestDate     DateTime
  status          String   @default("pending") // pending / approved / rejected / cancelled
  approverId      String?
  approvedDate    DateTime?
  rejectReason    String?
  receiptUrl      String?
  paymentMethod   String?  // card / cash / transfer
  attachmentNote  String?
  // 지출결의 필수 첨부 4종 (이미지/PDF URL)
  taxInvoiceImageUrl  String?  // 세금계산서
  businessRegUrl      String?  // 사업자등록증
  bankAccountUrl      String?  // 통장사본
  quotationUrl        String?  // 거래명세서/견적서
  // 결재라인
  approvalRoute   String   @default("internal") // internal / external
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project   Project? @relation(fields: [projectId], references: [id])
  requester User     @relation("ExpenseRequester", fields: [requesterId], references: [id])
  approver  User?    @relation("ExpenseApprover", fields: [approverId], references: [id])

  @@index([status])
  @@index([requesterId])
  @@index([projectId])
}

// ─────────────────────────────── 근태 ───────────────────────────────
model Attendance {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  checkIn         DateTime?
  checkOut        DateTime?
  status          String   @default("working") // working / off / leave / half_am / half_pm / absent / holiday
  checkInLocation String?
  checkInIp       String?
  checkOutIp      String?
  notes           String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  userId       String
  // 유형: annual / monthly / half_am / half_pm / public(공가) / sick(병가) /
  //       maternity(출산) / summer(하계) / family_event(경조) / disaster(재해) / health(보건) / other(기타)
  type         String
  approvalRoute String   @default("internal") // internal(3단계) / external(2단계, 박지윤 생략)
  startDate    DateTime
  endDate      DateTime
  days         Float
  reason       String?
  status       String    @default("pending") // pending / approved / rejected / cancelled
  // 결재 진행
  currentLevel Int       @default(1)
  finalApprovedAt DateTime?
  approverId   String?
  approvedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User  @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  approver  User? @relation("LeaveApprover", fields: [approverId], references: [id])
  approvals LeaveApproval[]

  @@index([userId])
  @@index([status])
  @@index([currentLevel])
}

// 휴가 신청 결재 라인 (단계별 결재 이력)
model LeaveApproval {
  id           String   @id @default(cuid())
  requestId    String
  level        Int      // 1=본부장 / 2=부대표 / 3=대표이사
  approverId   String
  status       String   @default("pending") // pending / approved / rejected / auto_passed
  comment      String?
  decidedAt    DateTime?
  createdAt    DateTime @default(now())

  request  LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver User         @relation("LeaveApprovalApprover", fields: [approverId], references: [id])

  @@unique([requestId, level])
  @@index([approverId, status])
}

// ─────────────────────────────── 업체별 관리비 (admin 전용) ───────────────────────────────
// 한 사업 = 1 (연도 × 클라이언트 업체)
// 각 사업당 여러 지출(MgmtFeeExpense) 보유. 지출은 매입 거래처(vendor)로 나감.
model MgmtFeeBudget {
  id                String   @id @default(cuid())
  year              Int
  seq               Int      // 연도별 일련번호 (1, 2, 3, ...)
  bizCategory       String?  // innovation(혁신바우처) / export(수출바우처) / tp(테크노파크) / contract(용역) — 엑셀 '구분' 컬럼 prefix 기반 자동분류
  clientCompanyId   String?  // 클라이언트 거래처(없으면 freetext)
  clientName        String   // 시트 기준 업체명 (제이오토 — 연도접미사 제거됨)
  rawCode           String?  // 엑셀 '구분' 원본 (aaa01, C1 등 — 참고용)
  projectId         String?  // 연결된 프로젝트 (optional, (연도,업체) 자동매칭)

  // 예산
  subsidy           BigInt   @default(0) // 정부보조금
  companyShare      BigInt   @default(0) // 기업분담금
  totalAmount       BigInt   @default(0) // 과제총액
  mgmtFeeAmount     BigInt   @default(0) // 관리비
  mgmtFeeRate       Float?               // 비율 (0.25 등)
  payableTotal      BigInt   @default(0) // 지급총액 (집행 가능 한도)
  overBudget        BigInt   @default(0) // 예산초과금
  notes             String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clientCompany     Company? @relation("MgmtFeeClient", fields: [clientCompanyId], references: [id])
  project           Project? @relation(fields: [projectId], references: [id])
  expenses          MgmtFeeExpense[]

  @@unique([year, seq])
  @@index([year])
  @@index([clientCompanyId])
  @@index([projectId])
}

model MgmtFeeExpense {
  id              String   @id @default(cuid())
  budgetId        String
  seq             Int      // 사업 내 지출 순번 (1, 2, 3, ...)

  vendorCompanyId String?  // 매입 거래처 (자동 신규생성 가능)
  vendorName      String   // 시트 기준 지불업체명 (담다 10%, 비트텍(재료비) 등)

  taxInvoiceDate  DateTime? // 세금계산서 발행일
  amount          BigInt   @default(0) // 지급액
  runningBalance  BigInt?              // 잔금 (시트값 그대로, 참고용)
  contractDone    Boolean  @default(false) // 계약서 작성
  paymentDate     DateTime?            // 입금완료일
  settlementDone  Boolean  @default(false) // 정산완료
  filed           Boolean  @default(false) // 보관
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget          MgmtFeeBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  vendorCompany   Company?      @relation("MgmtFeeVendor", fields: [vendorCompanyId], references: [id])

  @@index([budgetId])
  @@index([vendorCompanyId])
}

// ─────────────────────────────── 실적 관리 ───────────────────────────────
// 혁신/수출 서비스 수행 이력 (시트 import + DB 관리)
model TrackRecord {
  id              String   @id @default(cuid())
  type            String   // innovation(혁신) / export(수출)
  seqNo           Int?     // 엑셀 '번호' 컬럼 (1, 2, 3, ...)
  serviceName     String   // 서비스명
  serviceFee      BigInt   @default(0) // 서비스이용금액 / 서비스요금
  processedAmount BigInt?              // 처리금액 (수출 18컬럼 데이터)
  feeType         String?              // 요금형태 (건별협의 등)
  startDate       DateTime?
  endDate         DateTime?
  // 수요/참여 기업
  clientCompanyId String?
  clientName      String   // 수요기업명 / 참여기업
  processedDate   DateTime? // 처리일자
  status          String?  // 진행상태 (대금지급/입금완료 등)
  // 수출(18컬럼) 전용
  supportProgram  String?  // 지원사업명 (중기부 수출바우처_내수기업 등)
  year            Int?     // 사업 연도
  round           Int?     // 차수
  bizPeriodStart  DateTime?
  bizPeriodEnd    DateTime?
  bizNoChanged    Boolean  @default(false) // 사업자번호 변경여부
  country         String?
  region          String?
  notes           String?
  // 세금계산서 매칭
  electronicTaxInvoiceId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientCompany        Company?              @relation("TrackRecordClient", fields: [clientCompanyId], references: [id])
  electronicTaxInvoice ElectronicTaxInvoice? @relation("TrackRecordTaxInvoice", fields: [electronicTaxInvoiceId], references: [id])

  @@index([type])
  @@index([clientCompanyId])
  @@index([year])
  @@index([processedDate])
  @@index([status])
  @@index([electronicTaxInvoiceId])
}

// ─────────────────────────────── 컨설턴트 MD 플래너 ───────────────────────────────
// 사업(Project)별 컨설팅 비용으로 필요 MD 산정 + 컨설턴트(User)를 일별로 배정.
// 핵심 제약: 한 컨설턴트는 같은 날짜에 하나의 배정만 가능 (@@unique 로 강제).
model ConsultantPlan {
  id               String   @id @default(cuid())
  year             Int      @default(2026)
  title            String   // 사업명/업체명 (표시용, projectId 없을 시 freetext)
  projectId        String?  // 기존 프로젝트 연결 (optional)
  managerId        String?  // 담당자 (User)
  consultingBudget BigInt   @default(0) // 컨설팅 금액 (원)
  dailyRate        BigInt   @default(1000000) // 일 단가 (default 100만원)
  requiredMD       Int      @default(0) // 필요 MD (자동 = consultingBudget / dailyRate, 수동 조정 가능)
  startDate        DateTime? // 서비스 시작일
  endDate          DateTime? // 서비스 종료일
  contractEndDate  DateTime? // 계약 마감일
  serviceNumber    String?   // 서비스 구매번호
  notes            String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project          Project? @relation(fields: [projectId], references: [id])
  manager          User?    @relation("ConsultantPlanManager", fields: [managerId], references: [id])
  assignments      ConsultantAssignment[]

  @@index([year])
  @@index([projectId])
  @@index([managerId])
}

model ConsultantAssignment {
  id           String   @id @default(cuid())
  planId       String
  consultantId String   // User.id (내부직원 / 그 외 직원도 허용)
  date         DateTime @db.Date
  notes        String?
  createdAt    DateTime @default(now())

  plan         ConsultantPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  consultant   User           @relation("ConsultantAssignmentConsultant", fields: [consultantId], references: [id], onDelete: Cascade)

  // ★ 핵심: 한 컨설턴트의 같은 날짜에 단 하나의 배정만 (더블 부킹 방지)
  @@unique([consultantId, date])
  @@index([planId])
  @@index([date])
  @@index([consultantId, date])
}

// 출장 보고서 (전자결재)
model TripReport {
  id            String    @id @default(cuid())
  userId        String
  title         String    // 출장 제목
  destination   String?   // 출장지
  purpose       String?   // 출장 목적
  startDate     DateTime?
  endDate       DateTime?
  totalDays     Float?    // 출장 일수
  totalCost     BigInt    @default(0) // 총 비용 (₩)
  content       String?   // 출장 내용
  result        String?   // 출장 결과
  attachmentUrl String?
  status        String    @default("draft") // draft / pending / approved / rejected / cancelled
  approvalRoute String    @default("internal") // internal / external
  currentLevel  Int       @default(1)
  finalApprovedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
