# ──────────────────────────────────────────────────────
# DAEDONG CMC ERP - 환경변수 예시
# 운영(Vercel) 환경변수 페이지에 동일한 값으로 등록하세요.
# ──────────────────────────────────────────────────────

# PostgreSQL 연결 URL (Vercel Postgres / Neon / Supabase 등)
# 예: postgres://USER:PASS@HOST:5432/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/daedong_erp?sslmode=require"

# 세션 쿠키 HMAC 서명 키 (32자 이상 랜덤 권장)
# 생성: openssl rand -base64 48
SESSION_SECRET="change_me_to_a_long_random_string_at_least_32_chars"
